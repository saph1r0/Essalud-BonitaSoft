    },
    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.solicitudValidacion && $data.solicitudValidacion_asegurado ){",
        "\t//attach lazy references variables to parent variables",
        "\t$data.solicitudValidacion.asegurado = $data.solicitudValidacion_asegurado;",
        "\treturn {",
        "\t\t//map solicitudValidacion variable to expected task contract input",
        "\t\tsolicitudValidacionInput: {",
        "\t\t\tasegurado: $data.solicitudValidacion.asegurado ? {",
        "\t\t\t\tpersistenceId_string: $data.solicitudValidacion.asegurado.persistenceId_string !== undefined ? $data.solicitudValidacion.asegurado.persistenceId_string : null,",
        "\t\t\t\tdniPaciente: $data.solicitudValidacion.asegurado.dniPaciente !== undefined ? $data.solicitudValidacion.asegurado.dniPaciente : null",
        "\t\t\t} : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
    "asegurado_query" : {
      "type" : "url",
      "value" : [

    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.registroActual ){",
        "\treturn {",
        "\t\t//map registroActual variable to expected task contract input",
        "\t\tregistroActualInput: {",
        "\t\t\tnombreMedicamento: $data.registroActual.nombreMedicamento !== undefined ? $data.registroActual.nombreMedicamento : null,",
        "\t\t\tcantidadSolicitada: $data.registroActual.cantidadSolicitada !== undefined ? $data.registroActual.cantidadSolicitada : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
